# Облачное хранилище: приоритет Supabase → Firebase → localStorage.
# Скопируй в .env.local и заполни один из блоков.

# --- Supabase (рекомендуется) ---
# Пошаговая настройка: см. SUPABASE_SETUP.md
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Firebase (запасной вариант) ---
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_AUTH_DOMAIN=

# --- Песочница: чат с Claude (OpenRouter) ---
# Ключ с https://openrouter.ai/ — для правой панели «обсуждение с Claude»
VITE_OPENROUTER_API_KEY=

# --- Админ (только админ создаёт комнаты и видит логи) ---
# Секрет для входа: откройте сайт с ?admin=ВАШ_СЕКРЕТ — после этого вы админ в этой сессии
VITE_ADMIN_SECRET=
